<div class="mt-2 flex gap-1">
    @for (var i = 0; i < 4; i++)
    {
        var strength = GetStrength();
        var filled = i < strength;
        <div class="h-1 flex-1 rounded-full @(filled ? GetBarColor(strength) : "bg-muted") transition-colors duration-300"></div>
    }
</div>
@if (!string.IsNullOrEmpty(Password))
{
    <p class="text-xs mt-1 @GetTextColor()">@GetLabel()</p>
}

@code {
    [Parameter] public string Password { get; set; } = "";

    private int GetStrength()
    {
        if (string.IsNullOrEmpty(Password)) return 0;
        var score = 0;
        if (Password.Length >= 8) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(Password, "[A-Z]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(Password, "[0-9]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(Password, "[^a-zA-Z0-9]")) score++;
        return score;
    }

    private string GetBarColor(int strength) => strength switch
    {
        1 => "bg-red-500",
        2 => "bg-yellow-500",
        3 => "bg-blue-500",
        _ => "bg-green-500"
    };

    private string GetTextColor() => GetStrength() switch
    {
        1 => "text-red-500",
        2 => "text-yellow-500",
        3 => "text-blue-500",
        4 => "text-green-600",
        _ => "text-muted-foreground"
    };

    private string GetLabel() => GetStrength() switch
    {
        1 => "Weak",
        2 => "Fair",
        3 => "Good",
        4 => "Strong",
        _ => ""
    };
}
