@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="min-h-screen flex items-center justify-center @BackgroundClass px-4">
    <div class="fixed right-4 top-4 z-20">
        <LanguageSwitcher @rendermode="InteractiveAuto" />
    </div>

    <div class="w-full max-w-md">
        <div class="w-full bg-card shadow-sm rounded-2xl p-8">
            @Body
        </div>
    </div>
</div>

@code {
    private string BackgroundClass
    {
        get
        {
            var path = new Uri(Nav.Uri).AbsolutePath;
            return string.Equals(path, "/", StringComparison.Ordinal)
                ? "bg-background"
                : "bg-[url('/public_bg.jpg')] bg-cover bg-center bg-no-repeat";
        }
    }
}
