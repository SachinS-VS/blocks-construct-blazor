@inject SidebarState Sidebar
@implements IDisposable

<header class="relative z-10 flex h-14 shrink-0 items-center justify-between border-b bg-card px-4 lg:px-6">
    <div class="flex items-center gap-3">
        <button @onclick="Sidebar.ToggleMobile"
                class="rounded-md p-1.5 text-medium-emphasis transition-colors hover:bg-muted hover:text-high-emphasis lg:hidden"
                aria-label="Open navigation menu"
                aria-expanded="@Sidebar.IsMobileOpen"
                type="button">
            @((MarkupString)SvgIcons.Hamburger)
        </button>

        <button @onclick="Sidebar.Toggle"
                class="hidden rounded-md p-1.5 text-medium-emphasis transition-colors hover:bg-muted hover:text-high-emphasis lg:flex"
                aria-label="@(Sidebar.IsOpen ? "Collapse sidebar" : "Expand sidebar")"
                type="button">
            @((MarkupString)SvgIcons.Hamburger)
        </button>

        <DynamicBreadcrumb />
    </div>

    <div class="flex items-center gap-1 sm:gap-2">
        <LanguageSwitcher />

        <button class="relative rounded-full p-2 text-medium-emphasis transition-colors hover:bg-muted"
                aria-label="Notifications"
                type="button">
            @((MarkupString)SvgIcons.Bell)
        </button>

        <ProfileMenu />
    </div>
</header>

@code {
    protected override void OnInitialized() => Sidebar.OnChange += StateHasChanged;

    public void Dispose() => Sidebar.OnChange -= StateHasChanged;
}
