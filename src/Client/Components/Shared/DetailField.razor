<div class="flex flex-col gap-1 rounded-lg border bg-background px-4 py-3">
    <span class="text-xs font-semibold uppercase tracking-wide text-medium-emphasis">@Label</span>
    <span class="text-sm text-high-emphasis">@Value</span>
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
}