@page "/activation-success"
@rendermode InteractiveAuto
@layout AuthLayout
@inject LanguageState Lang
@implements IDisposable

<PageTitle>@T("SUCCESS")</PageTitle>

<div class="flex flex-col gap-6 text-center">
    <div class="flex justify-center">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
            <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
        </div>
    </div>

    <div>
        <h1 class="text-2xl font-bold text-high-emphasis">@T("ACCOUNT_ACTIVATED_SUCCESSFULLY")</h1>
        <p class="mt-2 text-base leading-6 text-medium-emphasis">
            @T("SUCCESSFULLY_SET_PASSWORD")
        </p>
    </div>

    <a href="/login" class="block w-full rounded-md bg-primary py-2.5 text-sm font-extrabold text-white hover:bg-primary/90 transition-colors">
        @T("GO_TO_LOGIN")
    </a>
</div>

@code {
    protected override void OnInitialized()
    {
        Lang.OnChange += HandleLanguageChanged;
    }

    private string T(string key) => Lang[key];

    private string Tr(string key, string fallback)
    {
        var value = Lang[key];
        return string.Equals(value, key, StringComparison.OrdinalIgnoreCase) ? fallback : value;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Lang.OnChange -= HandleLanguageChanged;
    }
}
