@page "/forgot-password"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))
@layout AuthLayout
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject LanguageState Lang
@implements IDisposable

<PageTitle>@T("FORGOT_PASSWORD")</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-bold text-high-emphasis">@T("FORGOT_PASSWORD")</h1>
        <p class="mt-1 text-sm font-normal text-medium-emphasis">@Tr("ENTER_YOUR_REGISTERED_EMAIL", "Enter your registered email and we'll send you a reset link.")</p>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">@_errorMessage</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="flex flex-col gap-4">
        <DataAnnotationsValidator />

        <div class="flex flex-col gap-1">
            <label class="text-sm font-normal text-high-emphasis">@T("EMAIL")</label>
            <InputText @bind-Value="_model.Email"
                       class="w-full rounded-md border border-input px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                       placeholder="@T("ENTER_YOUR_EMAIL_ADDRESS")" />
            <ValidationMessage For="@(() => _model.Email)" class="text-xs text-destructive" />
        </div>

        <button type="submit"
                class="mt-4 w-full rounded-md bg-primary py-2.5 text-sm font-extrabold text-white disabled:opacity-50 hover:bg-primary/90 transition-colors"
                disabled="@_isLoading">
            @(_isLoading ? T("LOADING") : T("SEND_RESET_LINK"))
        </button>
    </EditForm>

    <a href="/login" class="block text-center text-sm font-bold text-primary hover:underline">@T("GO_TO_LOGIN")</a>
</div>

@code {
    private ForgotPasswordRequest _model = new();
    private string _errorMessage = "";
    private bool _isLoading;

    protected override void OnInitialized()
    {
        Lang.OnChange += HandleLanguageChanged;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            await AuthService.ForgotPasswordAsync(_model.Email);
            Nav.NavigateTo("/email-sent");
        }
        catch
        {
            _errorMessage = $"{Tr("SOMETHING_WENT_WRONG", "Something went wrong.")} {Tr("PLEASE_TRY_AGAIN", "Please try again.")}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string T(string key) => Lang[key];

    private string Tr(string key, string fallback)
    {
        var value = Lang[key];
        return string.Equals(value, key, StringComparison.OrdinalIgnoreCase) ? fallback : value;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Lang.OnChange -= HandleLanguageChanged;
    }
}
