@page "/login"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))
@layout AuthLayout
@inject IAuthService AuthService
@inject ISsoService SsoService
@inject AppAuthStateProvider AuthState
@inject NavigationManager Nav
@inject LanguageState Lang
@implements IDisposable

<PageTitle>@T("LOG_IN")</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-bold text-high-emphasis">@T("LOG_IN")</h1>
        <div class="mt-1 flex items-center gap-1">
            <span class="text-sm font-normal text-medium-emphasis">@T("DONT_HAVE_ACCOUNT")</span>
            <a href="/signup" class="text-sm font-bold text-primary hover:underline">@T("SIGN_UP")</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert">
            <strong>@T("INVALID_CREDENTIALS")</strong> @_errorMessage
        </div>
    }

    @if (_loginOptions == null || _loginOptions.PasswordGrantAllowed)
    {
        <EditForm Model="_model" OnValidSubmit="HandleLogin" class="flex flex-col gap-4">
            <DataAnnotationsValidator />

            <div class="flex flex-col gap-1">
                <label class="text-sm font-normal text-high-emphasis">@T("EMAIL")</label>
                <InputText @bind-Value="_model.Username"
                           class="w-full rounded-md border border-input px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                           placeholder="@T("ENTER_YOUR_EMAIL_ADDRESS")" />
                <ValidationMessage For="@(() => _model.Username)" class="text-xs text-destructive" />
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-sm font-normal text-high-emphasis">@T("PASSWORD")</label>
                <PasswordInput @bind-Value="_model.Password" Placeholder="@T("ENTER_YOUR_PASSWORD")" />
                <ValidationMessage For="@(() => _model.Password)" class="text-xs text-destructive" />
            </div>

            <div class="flex justify-end">
                <a href="/forgot-password" class="text-sm text-primary hover:text-primary-600 hover:underline">
                    @T("FORGOT_PASSWORD")
                </a>
            </div>

            <button type="submit"
                    class="w-full rounded-md bg-primary py-2.5 text-sm font-extrabold text-white disabled:opacity-50 hover:bg-primary/90 transition-colors"
                    disabled="@_isLoading">
                @(_isLoading ? T("LOADING") : T("LOG_IN"))
            </button>
        </EditForm>
    }

    @if (_loginOptions?.PasswordGrantAllowed == true && _loginOptions?.SocialGrantAllowed == true)
    {
        <div class="flex items-center gap-3">
            <div class="flex-1 border-t border-border"></div>
            <span class="text-xs font-medium text-low-emphasis">OR</span>
            <div class="flex-1 border-t border-border"></div>
        </div>
    }

    @if (_loginOptions?.SocialGrantAllowed == true)
    {
        <SsoButtons LoginOptions="_loginOptions" />
    }
</div>

@code {
    private SignInRequest _model        = new();
    private string        _errorMessage = "";
    private bool          _isLoading;
    private LoginOptions? _loginOptions = null;

    protected override void OnInitialized()
    {
        Lang.OnChange += HandleLanguageChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var token = await AuthService.GetAccessTokenAsync();
        if (!string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/identity-management", replace: true);
            return;
        }

        _loginOptions = await SsoService.GetLoginOptionsAsync();
        StateHasChanged();
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var result = await AuthService.SignInAsync(_model.Username, _model.Password);

            if (result.EnableMfa)
            {
                Nav.NavigateTo($"/verify-mfa?mfa_id={result.MfaId}&mfa_type={result.MfaType}&user_name={Uri.EscapeDataString(_model.Username)}", replace: true);
                return;
            }

            AuthState.NotifyAuthStateChanged();
            Nav.NavigateTo("/identity-management", replace: true);
        }
        catch
        {
            _errorMessage = T("EMAIL_PASSWORD_NOT_VALID");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string T(string key) => Lang[key];

    private string Tr(string key, string fallback)
    {
        var value = Lang[key];
        return string.Equals(value, key, StringComparison.OrdinalIgnoreCase) ? fallback : value;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Lang.OnChange -= HandleLanguageChanged;
    }
}
