<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <div class="flex items-center justify-center gap-4 py-24 text-center">
                    <p class="text-medium-emphasis">You need to be logged in. <NavLink href="/login" class="text-primary hover:underline">Go to login</NavLink></p>
                </div>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Page Not Found</PageTitle>
        <LayoutView Layout="typeof(MainLayout)">
            <div class="flex flex-col items-center justify-center gap-4 py-24 text-center">
                <h1 class="text-6xl font-bold text-muted-foreground">404</h1>
                <p class="text-medium-emphasis">The page you're looking for doesn't exist.</p>
                <NavLink href="/identity-management" class="text-sm font-bold text-primary hover:underline">Go to IAM</NavLink>
            </div>
        </LayoutView>
    </NotFound>
</Router>
